# Historical CNB config template for the Tencent Lighthouse remote-first path.
# The active pipeline now lives in the repository-root .cnb.yml so the GitHub
# -> CNB one-way mirror cannot overwrite CNB-only pipeline edits.

main:
  push:
    - docker:
        image: node:22-bookworm
      stages:
        - name: feishu bridge tests
          script: |
            cd integrations/feishu-bridge
            npm install
            npm run check
            npm test

    - docker:
        image: rust:1.88-bookworm
      stages:
        - name: release version check
          script: |
            ./scripts/release/check-versions.sh

  web_trigger_lighthouse:
    - docker:
        image: cnbcool/default-build-env:latest
      stages:
        - name: deploy to lighthouse
          script: |
            set -euo pipefail

            : "${LIGHTHOUSE_HOST:?Set LIGHTHOUSE_HOST in CNB secrets}"
            : "${LIGHTHOUSE_SSH_TARGET:?Set LIGHTHOUSE_SSH_TARGET in CNB secrets}"
            : "${LIGHTHOUSE_SSH_PRIVATE_KEY:?Set LIGHTHOUSE_SSH_PRIVATE_KEY in CNB secrets}"

            if ! command -v ssh >/dev/null 2>&1 || ! command -v ssh-keyscan >/dev/null 2>&1; then
              apt-get update
              apt-get install -y openssh-client
            fi

            LIGHTHOUSE_SSH_PORT="${LIGHTHOUSE_SSH_PORT:-22}"
            HELPOFAI_REPO_BRANCH="${HELPOFAI_REPO_BRANCH:-main}"
            HELPOFAI_REPO_URL="${HELPOFAI_REPO_URL:-https://cnb.cool/helpofai.net/helpofai.git}"

            install -m 700 -d ~/.ssh
            printf '%s\n' "$LIGHTHOUSE_SSH_PRIVATE_KEY" > ~/.ssh/id_ed25519
            chmod 600 ~/.ssh/id_ed25519
            ssh-keyscan -p "$LIGHTHOUSE_SSH_PORT" -H "$LIGHTHOUSE_HOST" >> ~/.ssh/known_hosts

            ssh -p "$LIGHTHOUSE_SSH_PORT" "$LIGHTHOUSE_SSH_TARGET" \
              "HELPOFAI_REPO_BRANCH='$HELPOFAI_REPO_BRANCH' HELPOFAI_REPO_URL='$HELPOFAI_REPO_URL' bash -s" <<'REMOTE'
            set -euo pipefail

            if [ ! -d /opt/whalebro/helpofai/.git ]; then
              sudo -u helpofai git clone --branch "$HELPOFAI_REPO_BRANCH" "$HELPOFAI_REPO_URL" /opt/whalebro/helpofai
            fi

            cd /opt/whalebro/helpofai
            if [ -n "$(sudo -u helpofai git status --porcelain)" ]; then
              echo "Refusing to deploy over a dirty /opt/whalebro/helpofai checkout." >&2
              sudo -u helpofai git status --short
              exit 1
            fi

            sudo -u helpofai git fetch --all --tags
            if sudo -u helpofai git rev-parse --verify --quiet "refs/remotes/origin/$HELPOFAI_REPO_BRANCH" >/dev/null; then
              sudo -u helpofai git checkout -B "$HELPOFAI_REPO_BRANCH" "origin/$HELPOFAI_REPO_BRANCH"
            elif sudo -u helpofai git rev-parse --verify --quiet "refs/tags/$HELPOFAI_REPO_BRANCH" >/dev/null; then
              sudo -u helpofai git checkout --detach "$HELPOFAI_REPO_BRANCH"
            else
              sudo -u helpofai git checkout "$HELPOFAI_REPO_BRANCH"
              sudo -u helpofai git pull --ff-only
            fi

            sudo -iu helpofai bash -lc '
              set -euo pipefail
              . "$HOME/.cargo/env"
              cd /opt/whalebro/helpofai
              cargo install --path crates/cli --locked --force
              cargo install --path crates/tui --locked --force
            '

            sudo bash scripts/tencent-lighthouse/install-services.sh
            sudo systemctl restart helpofai-runtime
            sudo systemctl restart helpofai-feishu-bridge
            sudo bash scripts/tencent-lighthouse/doctor.sh
            REMOTE
